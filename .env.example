# Copy this file to .env and fill in your real values.
# Never commit .env; it is ignored by git.
CF_ACCOUNT_ID=your-cloudflare-account-id
CF_GATEWAY_ID=default
CF_AIG_TOKEN=your-cloudflare-ai-gateway-token

# Optional KovaFusion settings
KOVAFUSION_TRACE_DIR=./traces
KOVAFUSION_MAX_MODELS_PER_REQUEST=6
KOVAFUSION_MAX_REPAIRS_PER_CANDIDATE=2
KOVAFUSION_MAX_STEPS=8
KOVAFUSION_ENABLE_GPT55_PRO=false
KOVAFUSION_HARD_DOLLAR_CAP_USD=2.00
